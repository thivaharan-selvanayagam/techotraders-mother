<%- include('partials/head') %>
<%- include('partials/nav') %>

<!-- HERO -->
<section class="hero">
  <div class="hero__bg-grid"></div>
  <div class="hero__bg-gradient"></div>
  <svg class="hero__geo" id="heroGeo" viewBox="0 0 700 700" fill="none" xmlns="http://www.w3.org/2000/svg">
    <polygon points="350,10 690,195 690,505 350,690 10,505 10,195" fill="none" stroke="#0A4FD4" stroke-width="1"/>
    <polygon points="350,60 640,215 640,485 350,640 60,485 60,215" fill="none" stroke="#0A4FD4" stroke-width="0.7"/>
    <polygon points="350,110 590,235 590,465 350,590 110,465 110,235" fill="none" stroke="#0A4FD4" stroke-width="0.5"/>
    <line x1="350" y1="10" x2="350" y2="690" stroke="#0A4FD4" stroke-width="0.5"/>
    <line x1="10" y1="195" x2="690" y2="505" stroke="#0A4FD4" stroke-width="0.5"/>
    <line x1="690" y1="195" x2="10" y2="505" stroke="#0A4FD4" stroke-width="0.5"/>
    <circle cx="350" cy="350" r="40" fill="none" stroke="#0A4FD4" stroke-width="1"/>
    <circle cx="350" cy="350" r="8" fill="#0A4FD4"/>
  </svg>

  <div class="container">
    <div class="hero__content">
      <div class="hero__mono">TT / EST. 2024 / BATTICALOA, SL</div>
      <h1 class="hero__title">
        EMPOWERING<br>
        <span>PROGRESS</span><br>
        THROUGH TECH
      </h1>
      <p class="hero__subtitle">The parent organization driving innovation in Digital Solutions, Logistics, and Infrastructure across Sri Lanka.</p>
      <div class="hero__actions">
        <a href="/portfolio" class="btn btn--primary">
          Explore Our Ecosystem
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
        <a href="/about" class="btn btn--outline" style="border-color: rgba(255,255,255,0.3); color: rgba(255,255,255,0.8);">Our Story</a>
      </div>
    </div>
  </div>
  <div class="hero__scroll">SCROLL</div>
</section>

<!-- TRINITY -->
<section class="trinity">
  <div class="container">
    <div style="text-align:center; margin-bottom:3rem;">
      <div class="label" style="justify-content:center;">The Techo Ecosystem</div>
      <h2 class="section-heading" style="color: var(--dark);">Three Forces. One Vision.</h2>
    </div>
    <div class="trinity__grid">
      <div class="trinity-card trinity-card--labs fade-up">
        <div class="trinity-card__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M7 8h2M11 8h6M7 12h10"/></svg>
        </div>
        <div class="trinity-card__tag">The Brain</div>
        <h3>TECHO LABS</h3>
        <p>Architecting the Digital Future. We build and power the digital presence of businesses through Web Development, Digital Marketing, and Research.</p>
        <a href="/portfolio#labs" class="trinity-card__link">
          Explore Labs
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
      </div>

      <div class="trinity-card trinity-card--xpress fade-up">
        <div class="trinity-card__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <div class="trinity-card__tag">The Muscle</div>
        <h3>TECHO XPRESS</h3>
        <p>Redefining Modern Logistics. End-to-end courier and delivery solutions powered by tracking technology, built for speed and reliability.</p>
        <a href="/portfolio#xpress" class="trinity-card__link">
          Explore Xpress
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
      </div>

      <div class="trinity-card trinity-card--connect fade-up">
        <div class="trinity-card__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
        </div>
        <div class="trinity-card__tag">The Nerve System</div>
        <h3>TECHO CONNECT</h3>
        <p>Bridging Gaps Through Hardware. Manufacturing-grade antenna solutions and infrastructure that keep Sri Lanka connected in the 5G era.</p>
        <a href="/portfolio#connect" class="trinity-card__link">
          Explore Connect
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- STATS -->
<section class="stats-band">
  <div class="container">
    <div class="stats-band__grid">
      <div class="stat-item">
        <div class="stat-item__number" data-counter="3" data-suffix="+">0+</div>
        <div class="stat-item__label">Industry Verticals</div>
      </div>
      <div class="stat-item">
        <div class="stat-item__number" data-counter="50" data-suffix="+">0+</div>
        <div class="stat-item__label">Active Clients</div>
      </div>
      <div class="stat-item">
        <div class="stat-item__number" data-counter="100" data-suffix="+">0+</div>
        <div class="stat-item__label">Projects Delivered</div>
      </div>
      <div class="stat-item">
        <div class="stat-item__number" data-counter="1" data-suffix=" Vision">0</div>
        <div class="stat-item__label">Integrated Ecosystem</div>
      </div>
    </div>
  </div>
</section>

<!-- PHILOSOPHY -->
<section class="philosophy">
  <div class="container">
    <div class="philosophy__inner">
      <div class="philosophy__text">
        <div class="label">The Techo Philosophy</div>
        <h2 class="section-heading fade-up">The Roof That Holds It All Together</h2>
        <p class="fade-up">Derived from the concept of professional craftsmanship (Techne) and the idea of providing a stable "Techo" — a roof — we were founded with a singular vision: to bridge the gap between complex technology and everyday utility.</p>
        <p class="fade-up">Techo Traders is not just a holding company. It is a living ecosystem where each subsidiary feeds and strengthens the others. Our digital arm builds the software that powers our logistics. Our hardware expertise connects our clients to the world.</p>
        <div class="philosophy__values fade-up">
          <span class="value-pill">Synergy</span>
          <span class="value-pill">Innovation</span>
          <span class="value-pill">Precision</span>
          <span class="value-pill">Stability</span>
          <span class="value-pill">Integration</span>
        </div>
      </div>
      <div class="philosophy__geo">
        <svg viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%; opacity:0.5;">
          <circle cx="200" cy="200" r="180" stroke="#0A4FD4" stroke-width="0.8"/>
          <circle cx="200" cy="200" r="120" stroke="#0A4FD4" stroke-width="0.8"/>
          <circle cx="200" cy="200" r="60" stroke="#0A4FD4" stroke-width="0.8"/>
          <!-- Labs node -->
          <circle cx="200" cy="20" r="10" fill="#0A4FD4"/>
          <text x="200" y="10" fill="#ffffff" font-size="16" text-anchor="middle" font-family="monospace">LABS</text>
          <!-- Xpress node -->
          <circle cx="356" cy="290" r="10" fill="#D44F0A"/>
          <text x="356" y="280" fill="#ffffff" font-size="16" text-anchor="middle" font-family="monospace">XPRESS</text>
          <!-- Connect node -->
          <circle cx="44" cy="290" r="10" fill="#0AAD6E"/>
          <text x="44" y="280" fill="#ffffff" font-size="16" text-anchor="middle" font-family="monospace">CONNECT</text>
          <!-- Center -->
          <circle cx="200" cy="200" r="6" fill="#FFFFFF"/>
          <!-- Lines to center -->
          <line x1="200" y1="30" x2="200" y2="194" stroke="#0A4FD4" stroke-width="0.8" stroke-dasharray="4 3"/>
          <line x1="347" y1="284" x2="206" y2="204" stroke="#D44F0A" stroke-width="0.8" stroke-dasharray="4 3"/>
          <line x1="53" y1="284" x2="194" y2="204" stroke="#0AAD6E" stroke-width="0.8" stroke-dasharray="4 3"/>
          <!-- Lines between nodes -->
          <line x1="200" y1="30" x2="347" y2="284" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/>
          <line x1="347" y1="284" x2="53" y2="284" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/>
          <line x1="53" y1="284" x2="200" y2="30" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<!-- CTA BAND -->
<section style="background: var(--off-white); padding: 5rem 0;">
  <div class="container" style="text-align: center;">
    <div class="label" style="justify-content: center;">Ready to Collaborate?</div>
    <h2 class="section-heading fade-up" style="margin-bottom: 1.5rem;">Let's Build Something Together</h2>
    <p style="max-width: 500px; margin: 0 auto 2.5rem; color: var(--slate-light);">Whether you're a potential partner, investor, or client — we'd love to hear from you.</p>
    <a href="/contact" class="btn btn--primary">
      Start a Conversation
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
    </a>
  </div>
</section>

<%- include('partials/footer') %>
