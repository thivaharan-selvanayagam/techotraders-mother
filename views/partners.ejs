<%- include('partials/head') %>
<%- include('partials/nav') %>

<section class="partners-hero">
  <div class="page-hero__bg-grid"></div>
  <div class="container">
    <div class="hero__mono">TECHO TRADERS / INVESTOR & PARTNER RELATIONS</div>
    <h1 class="display-heading" style="color: var(--white); max-width: 700px;">BUILT FOR<br>THOSE WHO<br>THINK BIG.</h1>
  </div>
</section>

<!-- INTRO -->
<section class="section">
  <div class="container">
    <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 5rem; align-items: start;">
      <div>
        <div class="label">Why Techo Traders</div>
        <h2 class="section-heading" style="margin-bottom: 1.5rem;">An Ecosystem Built for Resilience</h2>
      </div>
      <div>
        <p style="font-size: 1.05rem; color: var(--slate-light); line-height: 1.8; margin-bottom: 1rem;">Techo Traders is not a single-vertical bet. It is a deliberately diversified ecosystem where three distinct industries — digital, logistics, and hardware — operate under a unified strategic vision. This structure creates a natural hedge: when one sector slows, others sustain momentum.</p>
        <p style="font-size: 1.05rem; color: var(--slate-light); line-height: 1.8;">More importantly, our subsidiaries are not independent. They are designed to work together — sharing technology, clients, and insights in ways that create compounding competitive advantages that no standalone company could replicate.</p>
      </div>
    </div>
  </div>
</section>

<!-- TECHO SYNERGY -->
<section class="section section--off">
  <div class="container">
    <div style="text-align: center; margin-bottom: 1rem;">
      <div class="label" style="justify-content: center;">The Smart Ecosystem</div>
      <h2 class="section-heading">Techo Synergy</h2>
      <p style="max-width: 600px; margin: 1rem auto 0; color: var(--slate-light);">Here's how our companies work together. This interconnection is the true value of Techo Traders — and it cannot be replicated by any of our subsidiaries acting alone.</p>
    </div>
    <div class="synergy-grid">
      <div class="synergy-card fade-up">
        <div class="synergy-card__arrow">
          <span style="color: var(--labs); font-weight:700;">LABS</span>
          <svg width="20" height="12" viewBox="0 0 20 12" fill="none"><path d="M0 6h18M13 1l5 5-5 5" stroke="#4A5B72" stroke-width="1.5"/></svg>
          <span style="color: var(--xpress); font-weight:700;">XPRESS</span>
        </div>
        <h4>Software Powers Logistics</h4>
        <p>Techo Labs develops the real-time tracking and fleet management software that powers Techo Xpress operations. Our couriers don't just deliver — they deliver with intelligence.</p>
      </div>
      <div class="synergy-card fade-up">
        <div class="synergy-card__arrow">
          <span style="color: var(--connect); font-weight:700;">CONNECT</span>
          <svg width="20" height="12" viewBox="0 0 20 12" fill="none"><path d="M0 6h18M13 1l5 5-5 5" stroke="#4A5B72" stroke-width="1.5"/></svg>
          <span style="color: var(--xpress); font-weight:700;">XPRESS</span>
        </div>
        <h4>Hardware Enables Coverage</h4>
        <p>Techo Connect's antenna infrastructure provides the communication backbone that allows Techo Xpress to maintain connectivity in remote delivery areas, ensuring no signal loss.</p>
      </div>
      <div class="synergy-card fade-up">
        <div class="synergy-card__arrow">
          <span style="color: var(--labs); font-weight:700;">LABS</span>
          <svg width="20" height="12" viewBox="0 0 20 12" fill="none"><path d="M0 6h18M13 1l5 5-5 5" stroke="#4A5B72" stroke-width="1.5"/></svg>
          <span style="color: var(--connect); font-weight:700;">CONNECT</span>
        </div>
        <h4>Digital Markets Hardware</h4>
        <p>Techo Labs builds and manages the digital marketing and e-commerce platform for Techo Connect — helping manufacturing-focused engineers reach the clients who need their products.</p>
      </div>
    </div>
  </div>
</section>

<!-- WHY PARTNER -->
<section class="section section--dark">
  <div class="container">
    <div style="text-align: center; margin-bottom: 3rem;">
      <div class="label" style="justify-content: center;">Partnership Tiers</div>
      <h2 class="section-heading">How We Work With Partners</h2>
    </div>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5px; background: rgba(255,255,255,0.08); border: 1.5px solid rgba(255,255,255,0.08); border-radius: 6px; overflow: hidden;">
      <div style="background: var(--dark-2); padding: 2.5rem 2rem;">
        <div class="label">Tier 01</div>
        <h4 style="font-family: var(--font-display); font-size: 1.6rem; color: white; letter-spacing: 0.03em; margin-bottom: 1rem;">STRATEGIC INVESTOR</h4>
        <p style="font-size: 0.9rem; color: rgba(255,255,255,0.6); line-height: 1.7;">For investors seeking equity participation in a diversified technology holding company with operations across three high-growth sectors.</p>
      </div>
      <div style="background: var(--dark-2); padding: 2.5rem 2rem; border-left: 1.5px solid rgba(255,255,255,0.08);">
        <div class="label">Tier 02</div>
        <h4 style="font-family: var(--font-display); font-size: 1.6rem; color: white; letter-spacing: 0.03em; margin-bottom: 1rem;">BUSINESS PARTNER</h4>
        <p style="font-size: 0.9rem; color: rgba(255,255,255,0.6); line-height: 1.7;">For businesses that wish to integrate with one or more of our subsidiaries — from reselling our hardware to co-branding logistics solutions.</p>
      </div>
      <div style="background: var(--dark-2); padding: 2.5rem 2rem; border-left: 1.5px solid rgba(255,255,255,0.08);">
        <div class="label">Tier 03</div>
        <h4 style="font-family: var(--font-display); font-size: 1.6rem; color: white; letter-spacing: 0.03em; margin-bottom: 1rem;">TECHNOLOGY CLIENT</h4>
        <p style="font-size: 0.9rem; color: rgba(255,255,255,0.6); line-height: 1.7;">For organizations seeking to leverage our integrated ecosystem — using Labs for digital, Xpress for delivery, and Connect for infrastructure simultaneously.</p>
      </div>
    </div>
    <div style="text-align: center; margin-top: 3rem;">
      <a href="/contact?dept=general" class="btn btn--primary">Request a Partnership Discussion</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
